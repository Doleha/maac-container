# Required
MAAC_SERVER_URL=wss://api.maacverify.ai/assessment
CLIENT_API_KEY=<issued per Phase 2 session by MaacVerify>
CLIENT_AI_ENDPOINT=http://internal-host/api/chat
CLIENT_AI_FORMAT=openai
CLIENT_AI_AUTH_TOKEN=<client internal API token>

# Optional
CLIENT_AI_MODEL=
CLIENT_AI_TIMEOUT_MS=120000
CLIENT_AI_MAX_RETRIES=3

# Required only when CLIENT_AI_FORMAT=custom
# JSON template; supported interpolation variables:
#   {{taskTitle}}, {{taskDescription}}, {{businessContext}},
#   {{scenarioRequirements}}, {{dataElements}}
# Example:
# CUSTOM_BODY_TEMPLATE={"prompt": "{{taskDescription}}", "context": "{{businessContext}}"}
CUSTOM_BODY_TEMPLATE=
